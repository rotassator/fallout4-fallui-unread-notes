build/
cmake-build-*/
.xmake/
vsxmake*/

# IDE workspace metadata (per-user, not shared)
.idea/
.vs/

# Local build helper for running cmake from a non-VS-dev shell
build.bat

# Python cache from tools/
__pycache__/

# Per-machine state for the submodule security-review hook
.claude/.submodule-review-state

# SWF working files — decompiled sources, P-code exports, backups, patches
swf_dump/
pcode_export/
pcode_verify/
*.swf.backup
*_patched.swf

# FallUI addon experiment (abandoned — Scaleform Loader.load doesn't work)
addon/

# Distribution archives (built manually, not tracked)
*.zip

# Nexus paste-source drafts (per-release ephemera kept locally for reference)
nexus-*.txt

# The DLL in dist/ is tracked — it's the distributable binary.
# Rebuilding updates it automatically via the xmake post-build step.
# Config files in dist/MCM/Config/UnreadNotes/ are tracked — they ship
# with the mod (defaults INI + MCM menu definition). The dist/ tree is
# Data/-relative (mirrors mod manager staging convention), so the deploy
# layout is dist/MCM/... → game's Data/MCM/...
