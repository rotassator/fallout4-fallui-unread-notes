// Windows version resource — generated by CMake from src/version.rc.in.
// Gives the compiled DLL a populated "Details" tab in File Explorer
// (File version / Product version / Description).

#include <winver.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION     @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 PRODUCTVERSION  @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 FILEFLAGSMASK   0x3fL
 FILEFLAGS       0x0L
 FILEOS          0x40004L    // VOS_NT_WINDOWS32
 FILETYPE        0x2L        // VFT_DLL
 FILESUBTYPE     0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"  // US English, Unicode
        BEGIN
            VALUE "CompanyName",      "rotassator"
            VALUE "FileDescription",  "FallUI - Unread Notes and Holotapes"
            VALUE "FileVersion",      "@PROJECT_VERSION@.0"
            VALUE "InternalName",     "UnreadNotes"
            VALUE "LegalCopyright",   "MIT License"
            VALUE "OriginalFilename", "UnreadNotes.dll"
            VALUE "ProductName",      "UnreadNotes"
            VALUE "ProductVersion",   "@PROJECT_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
